#!/usr/bin/env python3
"""Pop-launcher plugin for Toggl Track time tracking."""

import json
import os
import subprocess
import sys
import threading
import time
import unicodedata
import urllib.error
import urllib.request
from base64 import b64encode
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timezone
from pathlib import Path

PLUGIN_DIR = Path(__file__).parent
CONFIG_PATH = PLUGIN_DIR / "config.toml"
ICON_DIR = PLUGIN_DIR / "icons"
TOGGL_URL = "https://track.toggl.com"
API_BASE = "https://api.track.toggl.com/api/v9"

# Icons (absolute paths to bundled SVGs)
ICON_TIMER = str(ICON_DIR / "timer.svg")
ICON_PLAY = str(ICON_DIR / "play.svg")
ICON_STOP = str(ICON_DIR / "stop.svg")
ICON_PLUS = str(ICON_DIR / "plus.svg")
ICON_WARNING = str(ICON_DIR / "warning.svg")
ICON_SETTINGS = str(ICON_DIR / "settings.svg")

# Cache
_cache = {"entries": None, "current": None, "projects": None, "ts": 0}
_cache_lock = threading.Lock()
CACHE_TTL = 120
STALE_MAX = 600
DEFAULT_KEYWORD = "toggl"


def log(msg):
    print(msg, file=sys.stderr, flush=True)


# -- Config ------------------------------------------------------------------

def load_config():
    """Parse config.toml manually (no external deps)."""
    if not CONFIG_PATH.exists():
        return None, None, DEFAULT_KEYWORD
    token, wid, keyword = "", 0, DEFAULT_KEYWORD
    for line in CONFIG_PATH.read_text().splitlines():
        line = line.strip()
        if line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        # Strip inline comments, then surrounding whitespace and quotes
        val = val.split("#")[0].strip().strip('"').strip("'")
        if key == "api_token":
            token = val
        elif key == "workspace_id":
            try:
                wid = int(val)
            except ValueError:
                wid = 0
        elif key == "keyword":
            keyword = val or DEFAULT_KEYWORD
    return token or None, wid or None, keyword


def save_config(token, wid, keyword=DEFAULT_KEYWORD):
    """Write config.toml with restricted permissions."""
    CONFIG_PATH.write_text(
        '# Toggl Track API configuration\n'
        '# Get your API token from: https://track.toggl.com/profile\n\n'
        f'api_token = "{token}"\n'
        f'workspace_id = {wid}\n'
        f'keyword = "{keyword}"\n'
    )
    CONFIG_PATH.chmod(0o600)


def _fetch_workspaces(token):
    """Fetch the user's workspaces using the provided API token."""
    url = f"{API_BASE}/workspaces"
    cred = b64encode(f"{token}:api_token".encode()).decode()
    req = urllib.request.Request(url, method="GET")
    req.add_header("Authorization", f"Basic {cred}")
    req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
            if isinstance(data, list):
                return [(w["id"], w.get("name", f"Workspace {w['id']}")) for w in data]
    except Exception as e:
        log(f"Failed to fetch workspaces: {e}")
    return None


def run_setup(keyword=DEFAULT_KEYWORD):
    """Launch zenity dialogs to configure the plugin. Returns (token, wid) or None."""
    try:
        token = subprocess.run(
            ["zenity", "--entry",
             "--title=Toggl Track Setup",
             "--text=Enter your Toggl API token\n(find it at track.toggl.com/profile):",
             "--width=400"],
            capture_output=True, text=True, timeout=60,
        )
        if token.returncode != 0 or not token.stdout.strip():
            return None
        token = token.stdout.strip()

        # Try to fetch workspaces automatically
        workspaces = _fetch_workspaces(token)

        if workspaces and len(workspaces) == 1:
            # Only one workspace — use it directly
            wid = workspaces[0][0]
        elif workspaces and len(workspaces) > 1:
            # Multiple workspaces — let user pick
            items = []
            for ws_id, ws_name in workspaces:
                items.extend([str(ws_id), ws_name])
            proj = subprocess.run(
                ["zenity", "--list",
                 "--title=Select Workspace",
                 "--text=Choose your workspace:",
                 "--column=ID", "--column=Workspace",
                 "--hide-column=1",
                 "--width=400", "--height=300"] + items,
                capture_output=True, text=True, timeout=120,
            )
            if proj.returncode != 0 or not proj.stdout.strip():
                return None
            try:
                wid = int(proj.stdout.strip())
            except ValueError:
                return None
        else:
            # API call failed — fall back to manual entry
            wid_input = subprocess.run(
                ["zenity", "--entry",
                 "--title=Toggl Track Setup",
                 "--text=Could not fetch workspaces automatically.\nEnter your Workspace ID manually\n(go to track.toggl.com, look for ?wid= or &wid= in the URL):",
                 "--width=400"],
                capture_output=True, text=True, timeout=60,
            )
            if wid_input.returncode != 0 or not wid_input.stdout.strip():
                return None
            try:
                wid = int(wid_input.stdout.strip())
            except ValueError:
                subprocess.run(
                    ["zenity", "--error", "--text=Workspace ID must be a number.", "--width=300"],
                    timeout=10,
                )
                return None

        save_config(token, wid, keyword)
        return token, wid
    except FileNotFoundError:
        log("zenity not found")
        return None
    except Exception as e:
        log(f"Setup error: {e}")
        return None


# -- API helpers --------------------------------------------------------------

def _auth_header(token):
    cred = b64encode(f"{token}:api_token".encode()).decode()
    return f"Basic {cred}"


def api(method, path, token, body=None):
    url = f"{API_BASE}{path}"
    data = json.dumps(body).encode() if body else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Authorization", _auth_header(token))
    req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=5) as resp:
            raw = resp.read()
            return json.loads(raw) if raw else None
    except urllib.error.HTTPError as e:
        body = e.read().decode()
        log(f"API {method} {path} -> {e.code}: {body}")
        if e.code == 402 or e.code == 429:
            return {"_error": "rate_limit"}
        return None
    except Exception as e:
        log(f"API error: {e}")
        return None


def get_current(token):
    return api("GET", "/me/time_entries/current", token)


def get_recent(token):
    entries = api("GET", "/me/time_entries", token)
    return entries if isinstance(entries, list) else []


def get_projects(token, wid):
    projects = api("GET", "/me/projects", token)
    if isinstance(projects, list):
        return {p["id"]: p.get("name", "") for p in projects if p.get("workspace_id") == wid}
    return {}


def start_timer(token, wid, description, project_id=None, tags=None, billable=False):
    now = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    body = {
        "description": description,
        "start": now,
        "duration": -1,
        "workspace_id": wid,
        "billable": billable,
        "created_with": "pop-launcher-toggl",
    }
    if project_id:
        body["project_id"] = project_id
    if tags:
        body["tags"] = tags
    return api("POST", f"/workspaces/{wid}/time_entries", token, body)


def stop_timer(token, wid, entry_id):
    return api("PATCH", f"/workspaces/{wid}/time_entries/{entry_id}/stop", token)


# -- Formatting ---------------------------------------------------------------

def elapsed_str(start_iso):
    try:
        start = datetime.fromisoformat(start_iso.replace("Z", "+00:00"))
        delta = datetime.now(timezone.utc) - start
        secs = int(delta.total_seconds())
        h, m = secs // 3600, (secs % 3600) // 60
        return f"{h}h {m:02d}m" if h else f"{m}m"
    except Exception:
        return "?"


def entry_description(entry):
    return entry.get("description") or "(no description)"


def project_name(entry, projects):
    pid = entry.get("project_id")
    if pid and pid in projects:
        return projects[pid]
    return None


# -- IPC helpers ---------------------------------------------------------------

def send(obj):
    try:
        print(json.dumps(obj), flush=True)
    except BrokenPipeError:
        sys.exit(0)


def send_append(id_, name, description="", icon=ICON_TIMER):
    send({"Append": {
        "id": id_,
        "name": name,
        "description": description,
        "keywords": None,
        "icon": {"Name": icon},
        "exec": None,
        "window": None,
    }})


def send_clear():
    send({"Clear": None})


def send_finished():
    send({"Finished": None})


def send_fill(text):
    send({"Fill": text})


def send_close():
    send({"Close": None})


def send_context(id_, options):
    send({"Context": {"id": id_, "options": options}})


# -- Fuzzy matching ------------------------------------------------------------

def _strip_diacritics(text):
    """Remove diacritics (e.g. á→a, ž→z) and lowercase."""
    nfkd = unicodedata.normalize("NFKD", text)
    return "".join(c for c in nfkd if not unicodedata.combining(c)).lower()


def _fuzzy_score(query, text):
    """Score how well *query* fuzzy-matches *text*. Returns int or None."""
    query = _strip_diacritics(query)
    text_norm = _strip_diacritics(text)
    if not query:
        return 0

    qi = 0
    score = 0
    prev_match = -2

    for ti, tc in enumerate(text_norm):
        if qi < len(query) and tc == query[qi]:
            if ti == prev_match + 1:
                score += 3           # consecutive chars
            elif ti == 0 or text_norm[ti - 1] in " _-./":
                score += 2           # word boundary
            else:
                score += 1
            prev_match = ti
            qi += 1

    if qi < len(query):
        return None                  # not all query chars found

    # Prefer tighter matches (shorter target text)
    score += max(0, 10 - (len(text_norm) - len(query)))
    return score


# -- Plugin state --------------------------------------------------------------

class Plugin:
    def __init__(self):
        self.token, self.wid, self.keyword = load_config()
        self.current = None    # running timer entry
        self.entries = []      # recent entries (deduped)
        self.projects = {}     # id -> name
        self.results = []      # id -> action mapping
        self._rate_limited = False
        self._filter_text_value = ""
        self._pending_new_desc = None  # set when picking a project inline
        self._bg_refreshing = False
        # Pre-warm cache on startup so data is ready before user types
        if self.configured():
            self._start_bg_refresh()

    def configured(self):
        return self.token and self.wid

    def stop_current(self):
        """Stop the currently running timer, if any."""
        if self.current:
            eid = self.current.get("id")
            wid = self.current.get("workspace_id") or self.wid
            stop_timer(self.token, wid, eid)

    def _load_from_cache(self):
        with _cache_lock:
            self.current = _cache["current"]
            self.entries = _cache["entries"] or []
            self.projects = _cache["projects"] or {}

    def _do_refresh(self):
        """Fetch all data from API using parallel requests."""
        with ThreadPoolExecutor(max_workers=3) as pool:
            f_cur = pool.submit(get_current, self.token)
            f_rec = pool.submit(get_recent, self.token)
            f_prj = pool.submit(get_projects, self.token, self.wid)

            current = f_cur.result()
            raw = f_rec.result()
            projects = f_prj.result()

        now = time.monotonic()

        if isinstance(current, dict) and current.get("_error"):
            self._rate_limited = True
            with _cache_lock:
                _cache["ts"] = now
            return

        if not isinstance(projects, dict) or projects.get("_error"):
            if isinstance(projects, dict) and projects.get("_error"):
                self._rate_limited = True
            projects = {}
            with _cache_lock:
                _cache["ts"] = now
            if self._rate_limited:
                return

        self._rate_limited = False

        # Deduplicate by description+project, keep most recent
        seen = set()
        deduped = []
        for e in raw:
            if current and e.get("id") == current.get("id"):
                continue
            key = (e.get("description", ""), e.get("project_id"))
            if key not in seen:
                seen.add(key)
                deduped.append(e)
            if len(deduped) >= 20:
                break

        with _cache_lock:
            _cache["current"] = current
            _cache["entries"] = deduped
            _cache["projects"] = projects
            _cache["ts"] = now

        self.current = current
        self.entries = deduped
        self.projects = projects

    def _start_bg_refresh(self):
        if self._bg_refreshing:
            return
        self._bg_refreshing = True
        t = threading.Thread(target=self._bg_refresh_worker, daemon=True)
        t.start()

    def _bg_refresh_worker(self):
        try:
            self._do_refresh()
        except Exception as e:
            log(f"Background refresh error: {e}")
        finally:
            self._bg_refreshing = False

    def refresh(self, force=False):
        now = time.monotonic()
        cache_age = now - _cache["ts"] if _cache["ts"] else float('inf')

        if not force and cache_age < CACHE_TTL:
            # Fresh cache — use it directly
            self._load_from_cache()
            return

        if _cache["ts"] and cache_age < STALE_MAX:
            # Stale but usable — show stale data, refresh in background
            self._load_from_cache()
            self._start_bg_refresh()
            return

        # No cache or too old — blocking parallel fetch
        self._do_refresh()

    def _filter_text(self, query):
        """Extract filter text from the search query (everything after the keyword)."""
        q = query.lower()
        kw = self.keyword.lower()
        rest = query[len(kw):] if q.startswith(kw) else query
        return rest.strip()

    def _score_entry(self, entry, filter_text):
        """Score an entry against the filter. Returns int score or None if no match."""
        desc = entry_description(entry)
        proj = project_name(entry, self.projects) or ""
        best = None
        for text in (desc, proj):
            s = _fuzzy_score(filter_text, text)
            if s is not None and (best is None or s > best):
                best = s
        return best

    def _show_project_selection(self, filter_text):
        """Show project list in the launcher for the pending new timer."""
        self.results = []
        send_clear()
        idx = 0

        # Header — clicking cancels
        title = f"Creating: {self._pending_new_desc}" if self._pending_new_desc else "New timer (no description)"
        send_append(idx, title,
                    "Select a project below (click here to cancel)", ICON_PLUS)
        self.results.append(("cancel_new", None))
        idx += 1

        # No project option
        send_append(idx, "No project",
                    "Start timer without a project", ICON_PLAY)
        self.results.append(("select_project", None))
        idx += 1

        # Project list — fuzzy-filtered and sorted by score if typing
        if self.projects:
            if filter_text:
                scored = []
                for pid, pname in self.projects.items():
                    s = _fuzzy_score(filter_text, pname)
                    if s is not None:
                        scored.append((s, pid, pname))
                scored.sort(key=lambda x: x[0], reverse=True)
                project_list = [(pid, pname) for _, pid, pname in scored]
            else:
                project_list = sorted(self.projects.items(), key=lambda x: x[1].lower())

            for pid, pname in project_list:
                send_append(idx, pname, "Select project", ICON_PLAY)
                self.results.append(("select_project", pid))
                idx += 1

        send_finished()

    def handle_search(self, query):
        if not self.configured():
            send_clear()
            self.results = [("setup", None)]
            send_append(0, "Toggl Track: Setup required",
                        "Click to enter your API token & workspace ID",
                        ICON_SETTINGS)
            send_finished()
            return

        self.refresh()
        self.results = []
        send_clear()

        if self._rate_limited:
            self.results = [("none", None)]
            send_append(0, "API rate limit reached",
                        "Try again in a few minutes",
                        ICON_WARNING)
            send_finished()
            return

        filter_text = self._filter_text(query)
        self._filter_text_value = filter_text

        # Project selection mode for pending new timer
        if self._pending_new_desc is not None:
            self._show_project_selection(filter_text)
            return

        idx = 0

        # Running timer — click to stop (show if no filter or if it matches)
        if self.current:
            current_score = self._score_entry(self.current, filter_text) if filter_text else 0
            if not filter_text or current_score is not None:
                desc = entry_description(self.current)
                proj = project_name(self.current, self.projects)
                elapsed = elapsed_str(self.current.get("start", ""))
                detail = f"Elapsed: {elapsed}"
                if proj:
                    detail = f"{proj} \u2022 {detail}"
                send_append(idx, f"Running: {desc}",
                            f"{detail} \u2022 Click to stop", ICON_STOP)
                self.results.append(("stop", self.current))
                idx += 1

        # New timer — always shown; when filtering, uses typed text as description
        if filter_text:
            send_append(idx, f"New timer: {filter_text}",
                        "Start timer with project selection", ICON_PLUS)
        else:
            send_append(idx, "New timer",
                        "Start a new timer with project selection", ICON_PLUS)
        self.results.append(("new", None))
        idx += 1

        # Recent entries — fuzzy filter and sort by score
        max_shown = 8 if filter_text else 5
        if filter_text:
            scored = []
            for entry in self.entries:
                s = self._score_entry(entry, filter_text)
                if s is not None:
                    scored.append((s, entry))
            scored.sort(key=lambda x: x[0], reverse=True)
            ranked = [e for _, e in scored]
        else:
            ranked = self.entries

        shown = 0
        for entry in ranked:
            desc = entry_description(entry)
            proj = project_name(entry, self.projects)
            detail = proj or "No project"
            send_append(idx, desc, detail, ICON_PLAY)
            self.results.append(("start", entry))
            idx += 1
            shown += 1
            if shown >= max_shown:
                break

        send_finished()

    def handle_activate(self, id_):
        if id_ >= len(self.results):
            return
        action, entry = self.results[id_]

        if action == "stop":
            self.stop_current()
            _cache["ts"] = 0
            desc = entry_description(entry)
            send_fill(f"Stopped: {desc}")
            send_close()

        elif action == "new":
            self.refresh()
            self._pending_new_desc = self._filter_text_value or ""
            send_fill(f"{self.keyword} ")

        elif action == "select_project":
            self.stop_current()
            desc = self._pending_new_desc
            pid = entry  # project_id or None
            self._pending_new_desc = None
            start_timer(self.token, self.wid, desc, pid)
            _cache["ts"] = 0
            send_fill(f"Started: {desc}")
            send_close()

        elif action == "cancel_new":
            self._pending_new_desc = None
            send_fill(f"{self.keyword} ")

        elif action == "start":
            self.stop_current()
            desc = entry_description(entry)
            pid = entry.get("project_id")
            tags = entry.get("tags")
            billable = entry.get("billable", False)
            start_timer(self.token, self.wid, desc, pid, tags, billable)
            _cache["ts"] = 0
            send_fill(f"Started: {desc}")
            send_close()

        elif action == "setup":
            result = run_setup(self.keyword)
            if result:
                self.token, self.wid = result
                send_fill(f"{self.keyword} ")
            else:
                send_close()

        elif action == "none":
            pass

    def handle_context(self, id_):
        options = [
            {"name": "Open Toggl in browser", "description": "Open track.toggl.com"},
        ]
        if self.current:
            desc = entry_description(self.current)
            options.append({"name": "Stop timer", "description": f"Stop: {desc}"})
        send_context(id_, options)

    def handle_activate_context(self, id_, context):
        if context == 0:
            # Open Toggl in browser
            try:
                subprocess.Popen(
                    ["xdg-open", TOGGL_URL],
                    stdout=subprocess.DEVNULL,
                    stderr=subprocess.DEVNULL,
                )
            except Exception as e:
                log(f"xdg-open failed: {e}")
            send_close()

        elif context == 1 and self.current:
            desc = entry_description(self.current)
            self.stop_current()
            _cache["ts"] = 0
            send_fill(f"Stopped: {desc}")
            send_close()


def main():
    plugin = Plugin()

    try:
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            try:
                msg = json.loads(line)
            except json.JSONDecodeError:
                log(f"Bad JSON: {line}")
                continue

            if "Search" in msg:
                plugin.handle_search(msg["Search"])
            elif "Activate" in msg:
                val = msg["Activate"]
                if isinstance(val, int):
                    plugin.handle_activate(val)
            elif "Context" in msg:
                val = msg["Context"]
                if isinstance(val, int):
                    plugin.handle_context(val)
            elif "ActivateContext" in msg:
                ac = msg["ActivateContext"]
                if isinstance(ac, dict) and isinstance(ac.get("id"), int) and isinstance(ac.get("context"), int):
                    plugin.handle_activate_context(ac["id"], ac["context"])
            elif "Interrupt" in msg:
                pass  # nothing async to cancel
            elif "Exit" in msg:
                break
    except (BrokenPipeError, IOError):
        pass


if __name__ == "__main__":
    main()
